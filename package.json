{
  "name": "trianglify",
  "version": "5.0.0",
  "description": "Trianglify is a javascript library for generating colorful triangle meshes that can be used as SVG images and CSS backgrounds.",
  "type": "module",
  "sideEffects": false,
  "main": "dist/trianglify.cjs",
  "module": "dist/trianglify.mjs",
  "types": "dist/trianglify.d.ts",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/trianglify.d.ts",
      "import": "./dist/trianglify.mjs",
      "require": "./dist/trianglify.cjs",
      "default": "./dist/trianglify.mjs"
    },
    "./worker": {
      "default": "./dist/trianglify.worker.js"
    }
  },
  "scripts": {
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "jest",
    "build": "tsc -p tsconfig.build.json && rollup -c",
    "dev": "rollup -c -w",
    "publish-beta": "pnpm run build && pnpm publish --tag next",
    "ci": "pnpm run typecheck && pnpm run lint && pnpm run build && pnpm run test"
  },
  "dependencies": {
    "chroma-js": "^3.2.0",
    "delaunator": "^5.1.0"
  },
  "peerDependencies": {
    "canvas": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "canvas": {
      "optional": true
    }
  },
  "files": [
    "dist/",
    "Readme.md",
    "LICENSE"
  ],
  "directories": {
    "example": "examples"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/qrohlf/trianglify.git"
  },
  "keywords": [
    "svg",
    "canvas",
    "visualization",
    "pattern",
    "lowpoly"
  ],
  "jest": {
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    },
    "setupFiles": [
      "jest-canvas-mock"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "trianglify\\.bundle"
    ]
  },
  "author": "Quinn Rohlf <qr@qrohlf.com>",
  "license": "GPL-3.0",
  "packageManager": "pnpm@10.33.0",
  "bugs": {
    "url": "https://github.com/qrohlf/trianglify/issues"
  },
  "homepage": "https://github.com/qrohlf/trianglify",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/chroma-js": "^3.1.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "canvas": "^3.2.2",
    "eslint": "^10.1.0",
    "jest": "^30.3.0",
    "jest-canvas-mock": "^2.5.2",
    "jest-environment-jsdom": "^30.3.0",
    "rollup": "^4.60.0",
    "rollup-plugin-bundle-size": "^1.0.3",
    "rollup-plugin-dts": "^6.4.1",
    "ts-jest": "29.4.6",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "canvas"
    ]
  }
}
