{
  "name": "trianglify",
  "version": "5.0.0",
  "description": "Trianglify is a javascript library for generating colorful triangle meshes that can be used as SVG images and CSS backgrounds.",
  "type": "module",
  "main": "dist/trianglify.cjs",
  "module": "dist/trianglify.mjs",
  "types": "dist/trianglify.d.ts",
  "exports": {
    ".": {
      "types": "./dist/trianglify.d.ts",
      "import": "./dist/trianglify.mjs",
      "require": "./dist/trianglify.cjs",
      "default": "./dist/trianglify.mjs"
    }
  },
  "scripts": {
    "lint": "standard",
    "test": "jest",
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "publish-beta": "pnpm run build && npm publish --tag next",
    "ci": "pnpm run lint && pnpm run build && pnpm run test"
  },
  "dependencies": {
    "chroma-js": "^3.2.0",
    "delaunator": "^5.1.0"
  },
  "peerDependencies": {
    "canvas": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "canvas": {
      "optional": true
    }
  },
  "files": [
    "dist/",
    "Readme.md",
    "LICENSE"
  ],
  "directories": {
    "example": "examples"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/qrohlf/trianglify.git"
  },
  "keywords": [
    "svg",
    "canvas",
    "visualization",
    "pattern",
    "lowpoly"
  ],
  "standard": {
    "parser": "@babel/eslint-parser",
    "globals": [
      "self",
      "Worker"
    ],
    "ignore": [
      "dist",
      "**/vendor/**"
    ]
  },
  "jest": {
    "setupFiles": [
      "jest-canvas-mock"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "trianglify\\.bundle"
    ]
  },
  "author": "Quinn Rohlf <qr@qrohlf.com>",
  "license": "GPL-3.0",
  "packageManager": "pnpm@10.33.0",
  "bugs": {
    "url": "https://github.com/qrohlf/trianglify/issues"
  },
  "homepage": "https://github.com/qrohlf/trianglify",
  "devDependencies": {
    "canvas": "^3.2.2",
    "@babel/eslint-parser": "^7.25.0",
    "@babel/preset-env": "^7.29.2",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.0",
    "jest": "^30.3.0",
    "jest-canvas-mock": "^2.5.2",
    "jest-environment-jsdom": "^30.3.0",
    "rollup": "^4.60.0",
    "rollup-plugin-bundle-size": "^1.0.3",
    "standard": "^17.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "canvas"
    ]
  }
}
